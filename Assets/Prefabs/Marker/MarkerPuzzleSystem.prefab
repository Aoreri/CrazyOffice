      m_Calls: []
  m_text: "<b>G\xD6REV:</b> Akt\xF6rleri <b><color=#0055AA>MAV\u0130</color></b>,
    eylemleri (Use Case) <b><color=#CC7700>SARI</color></b> kalemle s\u0131ras\u0131yla
    i\u015Faretle.\r\n\r\n<b>Uygulama Beklentileri:</b>\r\n\r\n\r\n\u2022 <link=\"actor\">M\xFC\u015Fteriler</link>
    sistem \xFCzerinden kolayca <link=\"usecase\">sipari\u015F verebilmeli</link>.\r\n\r\n\r\n\u2022
    <link=\"actor\">Restoran y\xF6neticileri</link> stoklara g\xF6re <link=\"usecase\">men\xFCy\xFC
    g\xFCncelleyebilmeli</link>.\r\n\r\n\r\n\u2022 <link=\"actor\">Kuryeler</link>
    kendi ekranlar\u0131ndan <link=\"usecase\">teslimat durumunu de\u011Fi\u015Ftirebilmeli</link>."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 9098f7a9a31f51f43ab527ef7d6f4578, type: 2}
