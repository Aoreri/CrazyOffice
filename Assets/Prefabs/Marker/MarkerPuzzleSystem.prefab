  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4228b5e06dc764614a74f493fc2fa8be, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::RequirementHighlighter
  umlManager: {fileID: 9119320178249018694}
  documentText: {fileID: 5291630262696257155}
  highlightContainer: {fileID: 5754328591080536653}
  highlightPrefab: {fileID: 4613768592917034429, guid: 1c6f446f244ea96499e9e1b9d17f54c7, type: 3}
  randomTexts:
  - 'Smart Warehouse Management System



    TASK: Mark the actors with <color=#0055AA>BLUE</color>
    and the actions (Use Case) with <color=#CC7700>YELLOW</color> pen sequentially.



    Application
    Expectations:



    <link="actor_left">Warehouse operators</link> can quickly
    <link="usecase">scan barcode labels of incoming packages</link>.



    <link="actor_right">Inventory
    controllers</link> should be able to <link="usecase">track item locations within
    the facility</link>.



    <link="actor_right">Logistics managers</link> can
    automatically <link="usecase">generate shipping manifests for outgoing cargo</link>.'
  - 'Cloud Storage System



    TASK: Mark the actors with <color=#0055AA>BLUE</color>
    and the actions (Use Case) with <color=#CC7700>YELLOW</color> pen sequentially.



    Application
    Expectations:



    <link="actor_left">Standard users</link> can seamlessly
    <link="usecase">upload heavy files to the cloud folders</link>.



    <link="actor_right">Storage
    administrators</link> can easily <link="usecase">allocate disk space according
    to team requirements</link>.



    <link="actor_right">Security officers</link>
    can thoroughly <link="usecase">audit access logs to prevent data breaches</link>.'
  - 'Food Delivery App



    TASK: Mark the actors with <color=#0055AA>BLUE</color>
    and the actions (Use Case) with <color=#CC7700>YELLOW</color> pen sequentially.



    Application
    Expectations:



    <link="actor_left">Customers</link> can easily <link="usecase">place
    orders through the system</link>.



    <link="actor_right">Restaurant managers</link>
    should be able to <link="usecase">update the menu based on stock levels</link>.



    <link="actor_right">Couriers</link>
    can <link="usecase">change the delivery status from their own screens</link>.'
  highlightHeightMultiplier: 1.97
